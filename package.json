{
  "name": "pgk-name",
  "version": "0.0.2",
  "packageManager": "pnpm@11.1.2",
  "description": "",
  "type": "module",
  "keywords": [],
  "license": "MIT",
  "homepage": "https://github.com/estjs/pkg-name#readme",
  "bugs": "https://github.com/estjs/pkg-name/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/estjs/pkg-name.git"
  },
  "author": "jiangxd <jiangxd2016@gmail.com>",
  "funding": "https://github.com/sponsors/estjs",
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "sideEffects": false,
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint --cache --fix \"./src/*.{ts,tsx,js,vue}\"",
    "test": "vitest -r test",
    "play": "pnpm run -C playground dev",
    "play:build": "pnpm run -C playground build",
    "play:test": "pnpm run -C playground test -u",
    "play:preview": "pnpm run -C playground preview",
    "typecheck": "tsc  --noEmit",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build",
    "release": "bumpp --commit --tag --push && pnpm publish --access public--no-git-checks "
  },
  "devDependencies": {
    "@estjs/eslint-config": "^2.3.0",
    "@vitest/coverage-v8": "^4.1.6",
    "bumpp": "^11.1.0",
    "dayjs": "^1.11.20",
    "eslint": "^10.4.0",
    "pnpm": "^11.1.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
